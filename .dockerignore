# Keep the Docker build context small. Only the firmware project and the
# embedded dashboard asset are needed.
.git
**/.pio
**/__pycache__
*.log
out/
embedded/esp32-s3/.env

# Host-side Python tooling — not needed for the firmware build.
solecan-*.py
solecan_proto.py
util/
bms/
screenshot.svg

# Android sources — not needed; the firmware only consumes the canonical
# dashboard.html from the repo root (copied in by the Dockerfile).
android/
